  $
    (partial f_1) / (partial x) = y / (sin^2(x y)) - 2x \
    (partial f_1) / (partial y) = x dot sin^2(x y) \
    (partial f_2) / (partial x) = 2x \
    (partial f_2) / (partial y) = 4y \
